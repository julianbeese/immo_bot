# Telegram Bot Configuration
# Get these from @BotFather on Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# WhatsApp (optional). Links a WhatsApp account as a companion device via QR
# on first run. TARGET_PHONE = digits only (e.g. 4915112345678); receives
# notifications and is the only number allowed to send commands.
WHATSAPP_ENABLED=false
WHATSAPP_TARGET_PHONE=

# OpenAI API Key (optional, for message personalization)
OPENAI_ENABLED=false
OPENAI_API_KEY=sk-your_api_key_here

# IMAP inbox monitor (optional). Flags IS24 provider replies that came by email
# instead of via the IS24 chat. Requires OPENAI_ENABLED=true for classification.
# Use an app password (Gmail/Workspace: account → security → app passwords).
EMAIL_ENABLED=false
EMAIL_IMAP_HOST=imap.gmail.com:993
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_MAILBOX=INBOX

# Web dashboard (optional). Localhost-only status/settings/profiles UI.
# In Docker the container binds 0.0.0.0:8080 and compose publishes it to the
# host's 127.0.0.1:8080. View from your laptop via:  ssh -L 8080:localhost:8080 user@vm
WEB_ENABLED=false

# IS24 Cookie (export from browser while logged in)
# Open Developer Tools > Application > Cookies > www.immobilienscout24.de
# Copy all cookies as a single string: name1=value1; name2=value2; ...
IS24_COOKIE=

# Upstream proxy (optional). Use a residential DE proxy if the VM's IP is
# flagged by the IS24/DataDome WAF. URL = scheme+host+port only (no inline
# credentials — Chrome's --proxy-server ignores them; we answer auth via the
# DevTools fetch domain). Examples:
#   Shifter backconnect:   http://gw-de.shifter.io:7000
#   IPRoyal PAYG:          http://geo.iproyal.com:12321
#   Smartproxy residential: http://gate.smartproxy.com:7000
# For IS24 prefer DE-geo + sticky-session (encode in the username per provider,
# e.g. user-country-de-session-abc).
IS24_PROXY_URL=
IS24_PROXY_USER=
IS24_PROXY_PASS=

# Hard cap on proxy bandwidth per calendar month (MB). Stops new fetches when
# reached, resets on the 1st of each month. Set to your plan size minus ~10%
# headroom (e.g. 1800 for a 2 GB plan). 0 or empty = track only, no limit.
# Warning is logged at 80% consumption.
IS24_PROXY_BANDWIDTH_CAP_MB=1800

# Auto-contact is opt-in. Prefer environment variables over committing personal
# profile data to configs/config.yaml.
CONTACT_ENABLED=false
CONTACT_FIRST_NAME=
CONTACT_LAST_NAME=
CONTACT_EMAIL=
CONTACT_PHONE=
CONTACT_ADULTS=1

# Periodic database backups (VACUUM INTO + retention). Output lives in the
# persistent volume so SSH/rsync the directory to off-host storage to survive
# VM loss. Set BACKUP_INTERVAL=60s temporarily to verify the loop on a fresh
# install. BACKUP_RETENTION_DAYS=0 keeps only the newest snapshot.
BACKUP_ENABLED=true
BACKUP_INTERVAL=24h
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=data/backups
